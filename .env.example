# ─── Copy this file to .env and fill in your keys ───────────────────────────
#   cp .env.example .env
# .env is read automatically on startup (config.py calls load_dotenv()).

# REQUIRED — LLM provider. The agents run on DeepSeek via LiteLLM.
# Get a key at https://platform.deepseek.com/ . Startup fails fast without it.
DEEPSEEK_API_KEY=

# OPTIONAL — web search for the retriever (backbone/literature lookup).
# Priority: TAVILY_API_KEY first, then SERPER_API_KEY, else a keyless
# DuckDuckGo fallback (lower quality / rate-limited). Set ONE for reliable
# results. https://tavily.com/  |  https://serper.dev/
TAVILY_API_KEY=
SERPER_API_KEY=

# OPTIONAL — determinism / fast smoke runs (sensible defaults if unset).
# AOI_RANDOM_SEED / SEED — global seed for splits and training.
# AOI_SPLIT_PATH         — override the data-split checkpoint path.
# DRY_RUN=1              — tiny end-to-end run (few epochs / few samples).
# DRY_RUN_EPOCHS, DRY_RUN_SAMPLES, AOI_SMOKE_EPOCHS — sizes for dry runs.
# AOI_RANDOM_SEED=42
# SEED=42
# DRY_RUN=0
